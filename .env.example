# =================================================================
# Chave da API do Google Gemini (AI Studio)
# Pegue a sua em: https://aistudio.google.com/apikey
#
# IMPORTANTE: essa chave fica SÓ no servidor. Nunca é enviada pro
# navegador. Por isso o nome NÃO tem o prefixo NEXT_PUBLIC_.
#
# Local: copie este arquivo pra ".env.local" e cole sua chave.
# Produção (Vercel): adicione em Settings > Environment Variables.
# =================================================================
GEMINI_API_KEY=cole_sua_chave_aqui

# (opcional) modelo a usar. Padrão: gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash
